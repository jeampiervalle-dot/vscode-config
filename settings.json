{
  "workbench.colorTheme": "Catppuccin Frappé",
  "workbench.iconTheme": "catppuccin-frappe",

  "workbench.activityBar.location": "hidden",
  "workbench.statusBar.visible": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.editor.showTabs": "single",
  "workbench.sideBar.location": "right",
  "workbench.tree.indent": 8,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.tree.enableStickyScroll": false,
  "workbench.layoutControl.enabled": false,

  "window.titleBarStyle": "native",
  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "window.zoomLevel": 3,
  "breadcrumbs.enabled": false,
  "editor.lineNumbers": "on",
  "editor.fontSize": 14,
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.6,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "block",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.renderWhitespace": "none",
  "editor.guides.indentation": false,
  "editor.stickyScroll.enabled": false,
  "editor.renderLineHighlight": "none",
  "editor.occurrencesHighlight": "off",
  "editor.selectionHighlight": false,
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.colorDecorators": false,
  "editor.lightbulb.enabled": "off",
  "editor.hover.enabled": "off",
  "editor.showFoldingControls": "never",
  "editor.guides.bracketPairs": "active",

  "[php]": {
    "editor.hover.enabled": "on",
  },
  "[blade]": {
    "editor.hover.enabled": "on",
  },

  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": true,
  "explorer.decorations.colors": true,
  "git.decorations.enabled": false,
  "scm.diffDecorations": "none",

  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.minimumContrastRatio": 1,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.tabs.enabled": false,
  "terminal.integrated.defaultLocation": "viewlet",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.profiles.linux": {
    "bash": { "path": "bash", "args": ["-l"] },
    "zsh": { "path": "zsh" },
    "fish": { "path": "/usr/bin/fish" },
    "tmux": { "path": "tmux" },
    "pwsh": { "path": "pwsh" },
  },

  "extensions.ignoreRecommendations": true,
  "update.mode": "none",
  "telemetry.telemetryLevel": "off",
  "files.autoSave": "afterDelay",

  "workbench.colorCustomizations": {
    "[Catppuccin Frappé]": {
      "editor.background": "#303446",
      "sideBar.background": "#303446",
      "sideBar.foreground": "#c6d0f5",
      "panel.background": "#303446",
      "terminal.background": "#303446",
      "editorGroup.border": "#00000000",
      "panel.border": "#00000000",
      "terminal.border": "#00000000",
      "sideBar.border": "#00000000",
      "focusBorder": "#00000000",
      "list.activeSelectionBackground": "#414559",
      "list.inactiveSelectionBackground": "#414559",
      "list.hoverBackground": "#414559",
    },
  },

  "custom-ui-style.stylesheet": {
    ".sidebar": "border: none !important",
    ".panel": "border: none !important",
    ".monaco-editor .scroll-decoration": "display: none",
    ".notification-toast": "box-shadow: none !important",
    ".quick-input-widget.show-file-icons": "box-shadow: none !important",
    ".quick-input-list .scrollbar": "display: none",
  },
  "file_peek.activeLanguages": [
    "typescript",
    "javascript",
    "python",
    "php",
    "blade",
  ],
  "file_peek.searchFileExtensions": [
    ".js",
    ".ts",
    ".html",
    ".css",
    ".scss",
    ".php",
    ".blade.php",
  ],
  "editor.minimap.enabled": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "animations.Install-Method": "Custom UI Style",
  "custom-ui-style.external.imports": [
    "file:///home/jean/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.7/dist/updateHandler.js",
  ],
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal",
  ],
  "kilo-code.new.agentWorkStyle": "unset",
  "kilo-code.new.showTaskTimeline": true,
  "kilo-code.new.autocomplete.provider": "kilo",
  "kilo-code.new.autocomplete.model": "mistralai/codestral-2508",
  "chat.viewSessions.orientation": "stacked",
  "background.enabled": true,
}
